---
import { cms } from '@shared/cms/sheltify-access.ts';
import SectionRendererColumns from '@shared/components/sections/SectionRendererColumns.astro';
import RenderSectionAnimalList from 'article-renderer/components/RenderSectionAnimalList.svelte';
import RenderSectionFile from 'article-renderer/components/RenderSectionFile.svelte';
import type { CmsArticle, Section, SectionSpecial, SectionType } from 'sheltify-lib/article-types.ts';
import RenderSectionTitle from 'article-renderer/components/RenderSectionTitle.svelte';
import RenderSectionText from 'article-renderer/components/RenderSectionText.svelte';
import RenderSectionImages from 'article-renderer/components/RenderSectionImages.svelte';
import RenderSectionHero from 'article-renderer/components/RenderSectionHero.svelte';
import RenderSectionForm from 'article-renderer/components/RenderSectionForm.svelte';
import RenderSectionSponsor from 'article-renderer/components/special-sections/mft/RenderSectionSponsor.svelte';
import RenderSectionTierlisteHunde from 'article-renderer/components/special-sections/mft/RenderSectionTierlisteHunde.svelte';
import RenderSectionTierlisteAuswahl from 'article-renderer/components/special-sections/mft/RenderSectionTierlisteAuswahl.svelte';
import RenderSectionAnimalUpdates from 'article-renderer/components/RenderSectionAnimalUpdates.svelte';
import "article-renderer/styles/_index.scss"
import { animalsByArticleId } from 'sheltify-lib/animal-util.ts';

interface Props {
  article: CmsArticle;
}

const { article } = Astro.props;

await populateDynamicData();

const fullWidthSections: SectionType[] = ['hero'];
let rowindex = 0;
const hasTopHero = article.Structure.Rows[0]?.SectionType == 'hero';
const topPadding = hasTopHero ? -16 : 48;
const cssClasses = ['themable', 'article', 'sui', 'flex-y'];

async function populateDynamicData() {
  for (const section of article.Structure.Rows) {
    switch (section.SectionType) {
      case 'animal-list':
        section.TempFoundAnimals = await cms.getFilteredAnimals(section.Content);
        break;
      case 'animal-updates':
        section.TempAnimalsByArticle = animalsByArticleId(await cms.getAnimalUpdates(section.Content.days));
        break;
      case 'image':
          section.Content.MediaFiles = await cms.getMediaFilesByIds(section.Content.MediaFiles.map(i => i.ID));
    }
  }
}


const SpecialComponentMap: Record<string, any> = {
  Sponsor: RenderSectionSponsor,
  'Tierliste - Hunde': RenderSectionTierlisteHunde,
  'Tierliste - Auswahl': RenderSectionTierlisteAuswahl,
};

const allAnimalsByArticle = animalsByArticleId(await cms.animals);

---
<div style={'margin-top: ' + topPadding + 'px'} class:list={cssClasses}>

{
  article.Structure.Rows.map(section =>
    {
      // if a hero is the first row, we need negate of the initial top padding so it's placed right below the header
      const isTopHero = rowindex == 0 && section.SectionType == 'hero';
      rowindex++;
      const isFullWidth = fullWidthSections.includes(section.SectionType);
      const isFullWidthAndPadding = section.SectionType == 'columns' && section.Content.FullWidth;
        let comp;
        switch (section.SectionType) {
          case 'text':
            comp = <RenderSectionText section={section}/>;
            break;
          case 'title':
            comp = <RenderSectionTitle section={section}/>
            break;
          case 'separator-x':
            comp = <hr/>;
            break;
          case 'hero':
            comp = <RenderSectionHero section={section} client:visible/>;
            break;
          case 'animal-list':
            comp = <RenderSectionAnimalList section={section} allAnimalsByArticle={allAnimalsByArticle}/>;
            break;
          case 'image':
            comp = <RenderSectionImages section={section} client:load/>;
            break;
          case 'file':
            comp = <RenderSectionFile section={section} client:load/>;
            break;
          case 'columns':
            comp = <SectionRendererColumns section={section}/>;
            break;
          case 'form':
            comp = <RenderSectionForm section={section} submitUrl={cms.formSubmitUrl} client:visible/>;
            break;
          case 'html':
            comp = <div set:html={section.Content.Html}/>;
            break;
          case 'animal-updates':
            comp = <RenderSectionAnimalUpdates section={section}  allAnimalsByArticle={allAnimalsByArticle}/>;
          break;
          case 'special':
            const Component = SpecialComponentMap[section.Content.Type];
            comp = <Component section={section}/>
            break;
          default:
            comp = <div>Sektionstyp nicht unterstützt</div>;
            break;
          }
      const rowClasses = (isFullWidth ? ' full-width' : '')
        + (isFullWidthAndPadding ? ' full-width full-width-padding' : '')
        + (section.BackgroundColor ? ' themable themable-bg-' + section.BackgroundColor : '')

      return <div class={`row section-${section.SectionType}` + rowClasses}><div class={`row-wrapper` + rowClasses}>{comp}</div></div>
      }
    )
  }
</div>

<style is:global lang="scss">
  .article {
    //gap: var(--section-gap-y);
    .row {
      &:not(:first-of-type) {
        padding-top: calc(var(--section-gap-y) / 2);
        padding-bottom: calc(var(--section-gap-y) / 2);
      }

      .row-wrapper {
        &:not(.full-width) {
          width: var(--wrapper-width);
          max-width: 100%;
          margin-left: auto;
          margin-right: auto;
        }

        &.full-width-padding {
          width: 100%;
          padding: calc(var(--padding-article) / 2);
        }
      }

    }


  }
</style>
