---
import { cms } from "@shared/cms/sheltify-access.ts";
import Article from "./Article.astro";
import AnimalCV from './svelte-parts/AnimalCV.svelte'

interface Props {
  animalKind: string;
  animalNames: string;
}
const { animalKind, animalNames } = Astro.props;

const animals = await cms.getAnimalsByNames(animalKind, animalNames);
---

{
  animals.map((animal) => (
    <AnimalCV animal={animal}/>
  ))
}

<Article article={await cms.getArticle(animals[0].ArticleID ?? '')} />
