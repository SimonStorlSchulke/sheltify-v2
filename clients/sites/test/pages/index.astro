import { cms } from '@shared/cms/sheltify-access.ts';
import Page from '@shared/components/Page.astro';
import AnimateArticle from '@shared/interactive/AnimateArticle.astro';
import HhgLayout from '../layouts/HhgLayout.astro';

export async function getStaticPaths() {
  return cms.getStaticPathsPages();
}

const { path = '' } = Astro.params;
const seo = await cms.getSeoByPath(path ?? '');

---

<HhgLayout seo={seo}>
  <Page path={path ?? ''} />
</HhgLayout>

<AnimateArticle/>